# 이 파일을 복사해서 backend/.env 로 저장하고 값을 채우세요.
#   cp .env.example .env
# .env 는 서버 시작 시 자동 로드됩니다 (app/main.py). 절대 깃에 커밋하지 마세요.

# Gemini API 키 (슬롯 추출 + 계약서 설명 생성에 사용)
# 무료 키 발급: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# (선택) 사용할 Gemini 모델. 기본값 gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash

# (선택) Hugging Face 토큰 — 모델 다운로드 속도 제한 완화용. 없어도 동작.
# HF_TOKEN=
